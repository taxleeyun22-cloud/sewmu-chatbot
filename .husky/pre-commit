#!/usr/bin/env sh
# Phase Infra-1 (2026-05-09): pre-commit hook
# - 미러 자동 동기화 (A-3, 2026-05-17): root → apps/admin/public, drift 영구 차단
# - TypeScript type check (변경 코드 회귀 방지)
# - Vitest 단위 테스트 (전체, ~7초)
# 실패 시 commit 차단

# 0. 미러 동기화 (root 정본 → apps/admin/public) + 변경분 자동 stage
node scripts/sync-mirror.mjs
MIRROR_RC=$?
if [ $MIRROR_RC -ne 0 ]; then
  echo "❌ sync-mirror 실패. commit 차단."
  exit 1
fi
# 동기화된 미러 파일을 이번 commit 에 포함 (명시 경로만 — git add -A 금지 룰 준수)
git add apps/admin/public/admin.js apps/admin/public/admin-anal-review-faq.js \
  apps/admin/public/admin-business-tab.js apps/admin/public/admin-customer-dash.js \
  apps/admin/public/admin-docs.js apps/admin/public/admin-filing-review.js \
  apps/admin/public/admin-memos.js apps/admin/public/admin-rooms-list.js \
  apps/admin/public/admin-rooms-misc.js apps/admin/public/admin-rooms-msg.js \
  apps/admin/public/admin-search-bulk.js apps/admin/public/admin-users-tab.js \
  apps/admin/public/business.js apps/admin/public/index.js apps/admin/public/office.js \
  apps/admin/public/sw.js \
  apps/admin/public/admin.html apps/admin/public/admin-modals.html \
  apps/admin/public/articles.html apps/admin/public/business.html \
  apps/admin/public/index.html apps/admin/public/index-modals.html \
  apps/admin/public/memo-window.html apps/admin/public/office.html \
  apps/admin/public/staff.html apps/admin/public/admin.css \
  apps/admin/public/business.css apps/admin/public/index.css apps/admin/public/office.css \
  2>/dev/null || true
# (위 git add 는 일부 경로 부재해도 commit 막지 않음 — || true. 미러는 sync-mirror 가 정본)

# 1. Type check (전체)
npx tsc --noEmit
TSC_RC=$?
if [ $TSC_RC -ne 0 ]; then
  echo "❌ TypeScript type check 실패. commit 차단."
  exit 1
fi

# 2. Vitest 전체 (현재 ~7초)
npm test --silent
TEST_RC=$?
if [ $TEST_RC -ne 0 ]; then
  echo "❌ Vitest 단위 테스트 실패. commit 차단."
  exit 1
fi

echo "✅ pre-commit 검증 통과"
