#!/usr/bin/env sh
# Phase Infra-1 (2026-05-09): pre-commit hook
# - 미러 자동 동기화 (A-3, 2026-05-17): root → apps/admin/public, drift 영구 차단
# - TypeScript type check (변경 코드 회귀 방지)
# - Vitest 단위 테스트 (전체, ~7초)
# 실패 시 commit 차단

# 0. 미러 동기화 + 변경분 자동 stage (단일 소스: sync-mirror.mjs 의 FILES).
#    --stage 모드가 FILES 기준 명시 경로만 git add (git add -A 금지 룰 준수).
#    옛: hook 에 30경로 하드코딩 → FILES 와 dual-maintenance drift 약점. DRY 로 제거.
node scripts/sync-mirror.mjs --stage
MIRROR_RC=$?
if [ $MIRROR_RC -ne 0 ]; then
  echo "❌ sync-mirror 실패. commit 차단."
  exit 1
fi

# 1. Type check (전체)
npx tsc --noEmit
TSC_RC=$?
if [ $TSC_RC -ne 0 ]; then
  echo "❌ TypeScript type check 실패. commit 차단."
  exit 1
fi

# 2. Vitest 전체 (현재 ~7초)
npm test --silent
TEST_RC=$?
if [ $TEST_RC -ne 0 ]; then
  echo "❌ Vitest 단위 테스트 실패. commit 차단."
  exit 1
fi

echo "✅ pre-commit 검증 통과"
