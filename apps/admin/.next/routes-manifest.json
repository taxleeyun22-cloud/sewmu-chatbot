      "page": "/admin/businesses/[id]",
      "regex": "^/admin/businesses/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/businesses/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
