/*
  # 보안 헤더 — 전역 적용
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(self), payment=(), usb=(), magnetometer=(), gyroscope=(), fullscreen=(self)
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  # CSP: 외부 폰트/AG-Grid CDN만 허용. inline script/style은 현재 다수 사용 → 'unsafe-inline' 유지 (P2 리팩토링 대상)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://developers.kakao.com https://static.nid.naver.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob:; connect-src 'self' https://api.openai.com https://www.law.go.kr; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://kauth.kakao.com https://nid.naver.com; object-src 'none'; upgrade-insecure-requests

/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/articles.html
  Cache-Control: no-cache, no-store, must-revalidate

/admin.html
  Cache-Control: no-cache, no-store, must-revalidate

/staff.html
  Cache-Control: no-cache, no-store, must-revalidate

# 업로드·다운로드 프록시: 캐시 최소화 + 임베드 차단
/api/image
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Cache-Control: private, max-age=0

/api/file
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Cache-Control: private, max-age=0
