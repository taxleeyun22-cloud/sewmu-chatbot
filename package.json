{
  "name": "sewmu-chatbot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "세무회계 이윤 AI 세무 챗봇 + 사무실 OS",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/export-permissions.mjs && node scripts/build-modals.mjs",
    "build": "vite build",
    "postbuild": "node scripts/sync-assets.mjs",
    "build:strict": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2025-01-01",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "e2e:ui": "playwright test --ui",
    "ci": "npm run typecheck && npm run test && npm run build",
    "check-all": "npm run typecheck && npm test && npm run build && node scripts/check-bundle-size.mjs && node scripts/check-perf-budgets.mjs",
    "bundle:check": "node scripts/check-bundle-size.mjs",
    "perf:check": "node scripts/check-perf-budgets.mjs",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@auth/core": "^0.41.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trpc/server": "^11.17.0",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@playwright/test": "^1.48.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.10.0",
    "eslint-plugin-import": "^2.30.0",
    "globals": "^15.9.0",
    "happy-dom": "^15.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-static-copy": "^1.0.6",
    "vitest": "^2.1.1",
    "wrangler": "^3.78.0"
  },
  "dependencies": {
    "@nanostores/react": "^1.1.0",
    "@sentry/browser": "^10.57.0",
    "@sentry/react": "^10.57.0",
    "nanostores": "^0.11.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1"
  }
}
